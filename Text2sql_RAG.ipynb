import streamlit as st
import pandas as pd
import duckdb
import faiss
import numpy as np
import boto3
import io
import json
from sqlalchemy import create_engine

# ---------------------- AWS BEDROCK SETUP ---------------------- #
bedrock_client = boto3.client("bedrock-runtime", region_name="us-east-1")
CLAUDE_MODEL_ID = "anthropic.claude-3-5-sonnet-20241022-v2:0"
TITAN_EMBED_MODEL_ID = "amazon.titan-embed-text-v2:0"

# ---------------------- DATA LOADING ---------------------- #
def load_s3_excel(bucket_name, prefix):
    """Load Excel sheets from S3 as DataFrames."""
    s3 = boto3.client("s3")
    objs = s3.list_objects_v2(Bucket=bucket_name, Prefix=prefix).get("Contents", [])
    dfs = {}
    for obj in objs:
        if obj['Key'].endswith((".xls", ".xlsx")):
            excel_obj = s3.get_object(Bucket=bucket_name, Key=obj["Key"])
            xls = pd.ExcelFile(io.BytesIO(excel_obj['Body'].read()))
            for sheet in xls.sheet_names:
                df = xls.parse(sheet)
                df.columns = [c.strip().replace(" ", "_") for c in df.columns]
                dfs[f"{obj['Key'].split('/')[-1].replace('.xlsx','')}_{sheet}"] = df
    return dfs

def load_db_tables(db_type, host, port, db_name, user, password, tables=None):
    """Load tables from a traditional database as DataFrames."""
    if db_type == "postgresql":
        conn_str = f"postgresql://{user}:{password}@{host}:{port}/{db_name}"
    elif db_type == "mysql":
        conn_str = f"mysql+pymysql://{user}:{password}@{host}:{port}/{db_name}"
    elif db_type == "mssql":
        conn_str = f"mssql+pyodbc://{user}:{password}@{host}:{port}/{db_name}?driver=ODBC+Driver+17+for+SQL+Server"
    else:
        raise ValueError("Unsupported DB type")

    engine = create_engine(conn_str)
    if tables is None:
        tables = engine.table_names()
    dfs = {}
    for t in tables:
        df = pd.read_sql_table(t, engine)
        df.columns = [c.strip().replace(" ", "_") for c in df.columns]
        dfs[t] = df
    return dfs

def register_in_duckdb(dfs):
    """Register all loaded DataFrames in DuckDB in-memory."""
    conn = duckdb.connect(":memory:")
    for name, df in dfs.items():
        conn.register(name, df)
    return conn

# ---------------------- SCHEMA CHUNKING ---------------------- #
def chunk_schema(dfs, chunk_size=5):
    """Split large schemas into chunks for RAG retrieval."""
    chunks = []
    for table_name, df in dfs.items():
        cols = df.columns.tolist()
        for i in range(0, len(cols), chunk_size):
            chunk_cols = cols[i:i+chunk_size]
            chunks.append(f"{table_name}: {', '.join(chunk_cols)}")
    return chunks

# ---------------------- RAG with Titan Embeddings + FAISS ---------------------- #
def embed_text_titan(text_list):
    """Get embeddings for a list of texts using Titan embedding model."""
    embeddings = []
    for text in text_list:
        body = json.dumps({"inputText": text})
        resp = bedrock_client.invoke_model(
            body=body,
            modelId=TITAN_EMBED_MODEL_ID,
            accept="application/json",
            contentType="application/json"
        )
        result = json.loads(resp["body"].read().decode("utf-8"))
        emb = np.array(result["results"][0]["embedding"], dtype="float32")
        embeddings.append(emb)
    return np.vstack(embeddings)

def build_faiss_index(schema_chunks):
    """Build a FAISS index over Titan embeddings for schema chunks."""
    embeddings = embed_text_titan(schema_chunks)
    dim = embeddings.shape[1]
    index = faiss.IndexFlatL2(dim)
    index.add(embeddings)
    return index, embeddings

def retrieve_relevant_schema(query, schema_chunks, faiss_index):
    """Retrieve top relevant schema chunks using FAISS + Titan embeddings."""
    q_vec = embed_text_titan([query])
    _, ind = faiss_index.search(q_vec, 5)
    return "\n".join(schema_chunks[i] for i in ind[0])

# ---------------------- SQL EXECUTION ---------------------- #
def is_valid_sql(q, conn):
    try:
        conn.execute(f"EXPLAIN {q}")
        return True
    except:
        return False

def run_sql(q, conn):
    try:
        df = conn.execute(q).fetchdf()
        return df.to_html(index=False), df
    except Exception as e:
        return f"Error: {e}", None

# ---------------------- SQL GENERATION WITH CLAUDE SONNET ---------------------- #
sql_cache = {}
history_q, history_sql = [], []

def generate_sql(natural_query, conn, schema_chunks, faiss_index):
    if natural_query in sql_cache:
        return sql_cache[natural_query]

    relevant_schema = retrieve_relevant_schema(natural_query, schema_chunks, faiss_index)
    forbidden = ["DROP", "DELETE", "ALTER", "--"]

    prompt = f"""
You are an expert SQL assistant. Using ONLY the schema below, generate a safe DuckDB SQL query:

Relevant Schema:
{relevant_schema}

User Query: {natural_query}

Constraints:
- Do not use destructive SQL: {', '.join(forbidden)}
- Validate tables and columns exist
- Reflect assumptions if uncertain
Return a syntactically correct SQL query only.
SQL:
"""

    body = json.dumps({"inputText": prompt})
    response = bedrock_client.invoke_model(
        body=body,
        modelId=CLAUDE_MODEL_ID,
        accept="application/json",
        contentType="application/json"
    )
    result = json.loads(response["body"].read().decode("utf-8"))
    sql_q = result["results"][0]["outputText"].strip()

    if any(x in sql_q.upper() for x in forbidden) or not is_valid_sql(sql_q, conn):
        return None

    sql_cache[natural_query] = sql_q
    history_q.append(natural_query)
    history_sql.append(sql_q)
    return sql_q

# ---------------------- STREAMLIT UI ---------------------- #
st.set_page_config(page_title="Claude RAG SQL App", layout="wide")
st.title("Natural Language to SQL with RAG (Claude Sonnet + Titan Embeddings)")

# --- Load Data ---
dfs_s3 = load_s3_excel("your-bucket", "your-prefix/")
dfs_db = load_db_tables("postgresql", "host", 5432, "dbname", "user", "pass")
all_dfs = {**dfs_s3, **dfs_db}

conn = register_in_duckdb(all_dfs)
schema_chunks = chunk_schema(all_dfs)
faiss_index, _ = build_faiss_index(schema_chunks)

query = st.text_input("Ask a database question:")

if st.button("Generate SQL") and query:
    sql_query = generate_sql(query, conn, schema_chunks, faiss_index)
    if sql_query:
        st.subheader("Generated SQL")
        st.code(sql_query, language="sql")
        html, df_out = run_sql(sql_query, conn)
        st.subheader("Result")
        st.write(html, unsafe_allow_html=True)
        st.markdown("---")
        st.subheader("Similar Previous Queries")
        for q, s in zip(history_q, history_sql):
            st.markdown(f"**Q:** {q}\n**SQL:** `{s}`")
    else:
        st.error("Unable to generate a valid SQL query.")
